{
    "name": "@aria51/mcp",
    "version": "0.1.4",
    "description": "MCP server for aria51 accessibility scanner",
    "main": "dist/server.js",
    "type": "module",
    "bin": {
        "aria51-mcp": "./bin/mcp-server.js"
    },
    "files": [
        "dist",
        "bin",
        "README.md"
    ],
    "scripts": {
        "build": "rm -rf dist .tsbuildinfo && tsc",
        "dev": "tsc --watch",
        "start": "node ./dist/server.js"
    },
    "keywords": [
        "mcp",
        "accessibility",
        "a11y",
        "wcag",
        "axe"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/justinleeirizarry/aria51.git",
        "directory": "packages/mcp"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@aria51/core": "workspace:*",
        "@aria51/ai-auditor": "workspace:*",
        "@modelcontextprotocol/sdk": "^1.22.0",
        "@ai-sdk/openai": "^1.0.0",
        "ai": "^5.0.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "typescript": "^5.3.0"
    }
}
