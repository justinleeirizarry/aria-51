{
    "name": "@aria51/agent",
    "version": "0.1.0",
    "description": "Autonomous accessibility auditing agent harness powered by Claude",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rm -rf dist && tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "keywords": [
        "accessibility",
        "a11y",
        "agent",
        "harness",
        "wcag",
        "claude",
        "anthropic"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/justinirizarry/aria-51.git",
        "directory": "packages/agent"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@aria51/core": "workspace:*",
        "@aria51/ai-auditor": "workspace:*",
        "@anthropic-ai/sdk": "^0.80.0",
        "effect": "^3.19.15",
        "zod": "^3.22.0",
        "zod-to-json-schema": "^3.22.0"
    },
    "peerDependencies": {
        "ai": ">=4.0.0",
        "@ai-sdk/openai": ">=1.0.0"
    },
    "peerDependenciesMeta": {
        "ai": {
            "optional": true
        },
        "@ai-sdk/openai": {
            "optional": true
        }
    },
    "devDependencies": {
        "@ai-sdk/openai": "^1.0.0",
        "@types/node": "^20.10.0",
        "ai": "^5.0.0",
        "typescript": "^5.3.0",
        "vitest": "^4.0.13"
    }
}
