{
    "name": "aria51",
    "version": "0.1.4",
    "description": "CLI for accessibility testing — axe-core, keyboard navigation, WCAG 2.2 checks, and AI-powered auditing",
    "main": "dist/index.js",
    "type": "module",
    "exports": {
        ".": "./dist/index.js",
        "./dist/index.js": "./dist/index.js"
    },
    "bin": {
        "aria51": "./bin/cli.js"
    },
    "files": [
        "dist",
        "bin",
        "README.md"
    ],
    "scripts": {
        "build": "rm -rf dist .tsbuildinfo && tsc",
        "dev": "tsc --watch",
        "start": "node ./bin/cli.js",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "keywords": [
        "accessibility",
        "a11y",
        "cli",
        "wcag",
        "axe"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/justinleeirizarry/aria51.git",
        "directory": "packages/cli"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@aria51/core": "workspace:*",
        "@aria51/ai-auditor": "workspace:*",
        "chalk": "^5.3.0",
        "dotenv": "^17.2.3",
        "ink": "^4.4.1",
        "ink-spinner": "^5.0.0",
        "@ai-sdk/openai": "^1.0.0",
        "ai": "^5.0.0",
        "meow": "^13.1.0",
        "react": "^18.3.1"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@types/react": "^18.3.1",
        "ink-testing-library": "^4.0.0",
        "typescript": "^5.3.0",
        "vitest": "^4.0.13"
    }
}
